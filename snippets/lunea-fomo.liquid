<script>
(function() {
  var purchases = [
    { name: "Valentina M.", city: "Medellín", mins: 2 },
    { name: "Camila R.", city: "Medellín", mins: 5 },
    { name: "Daniela L.", city: "Medellín", mins: 8 },
    { name: "Sofía P.", city: "Medellín", mins: 11 },
    { name: "Andrea C.", city: "Cali", mins: 14 },
    { name: "Mariana V.", city: "Medellín", mins: 3 },
    { name: "Laura T.", city: "Barranquilla", mins: 19 },
    { name: "Natalia G.", city: "Medellín", mins: 6 },
    { name: "Isabela M.", city: "Pereira", mins: 22 },
    { name: "Carolina S.", city: "Medellín", mins: 9 }
  ];

  function initFomo() {
    var style = document.createElement('style');
    style.textContent = '.lp-fomo{position:fixed;bottom:24px;left:20px;z-index:9999;background:#fff;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.14);padding:12px 16px 12px 12px;display:flex;align-items:center;gap:12px;max-width:290px;transform:translateX(-120%);transition:transform .4s cubic-bezier(.34,1.56,.64,1);border-left:4px solid #1f8a55;font-family:"DM Sans",system-ui,sans-serif}.lp-fomo.lp-fomo--visible{transform:translateX(0)}.lp-fomo__icon{font-size:26px;flex-shrink:0;line-height:1}.lp-fomo__body{flex:1;min-width:0}.lp-fomo__name{font-size:13px;font-weight:700;color:#1a2e35;margin:0 0 2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.lp-fomo__text{font-size:12px;color:#4a6572;margin:0 0 3px;line-height:1.3}.lp-fomo__time{font-size:11px;color:#1f8a55;font-weight:600;margin:0}.lp-fomo__close{position:absolute;top:6px;right:8px;background:none;border:none;cursor:pointer;font-size:14px;color:#aaa;line-height:1;padding:0}';
    document.head.appendChild(style);

    var el = document.createElement('div');
    el.className = 'lp-fomo';
    el.setAttribute('role', 'status');
    el.setAttribute('aria-live', 'polite');
    el.innerHTML = '<span class="lp-fomo__icon">🛍️</span><div class="lp-fomo__body"><p class="lp-fomo__name"></p><p class="lp-fomo__text">acaba de pedir su <strong>Lunea</strong></p><p class="lp-fomo__time"></p></div><button class="lp-fomo__close" aria-label="Cerrar">✕</button>';
    document.body.appendChild(el);

    var nameEl  = el.querySelector('.lp-fomo__name');
    var timeEl  = el.querySelector('.lp-fomo__time');
    var closeBtn = el.querySelector('.lp-fomo__close');
    var idx = 0, timer;

    function show() {
      var p = purchases[idx % purchases.length];
      nameEl.textContent = p.name + ' · ' + p.city;
      timeEl.textContent = 'hace ' + p.mins + ' minutos';
      el.classList.add('lp-fomo--visible');
      idx++;
      timer = setTimeout(hide, 5000);
    }
    function hide() {
      el.classList.remove('lp-fomo--visible');
      setTimeout(show, 9000);
    }
    closeBtn.addEventListener('click', function() {
      clearTimeout(timer);
      el.classList.remove('lp-fomo--visible');
      setTimeout(show, 20000);
    });
    setTimeout(show, 6000);
  }

  // Espera a que el navegador esté libre antes de montar el popup
  if ('requestIdleCallback' in window) {
    requestIdleCallback(initFomo, { timeout: 3000 });
  } else {
    setTimeout(initFomo, 2000);
  }
})();
</script>
