{%- comment -%}
  CO · Mercado Envíos Full badges — va ARRIBA del co-couriers block.
  Izquierda: logo Envíos Full (imagen). Derecha: badges de entrega y devolución.
{%- endcomment -%}

<div class="co-ml-full">

  <div class="co-ml-full__badge co-ml-full__badge--delivery">
    <span class="co-ml-full__badge-text">Llega gratis en 1–3 días</span>
    <img src="https://cdn.shopify.com/s/files/1/0811/0984/4194/files/Gemini_Generated_Image_4lgeza4lgeza4lge22_430x.png?v=1782390850" alt="Mercado Envíos Full" class="co-ml-full__pill-img" loading="lazy">
  </div>

  <div class="co-ml-full__badge co-ml-full__badge--return">
    <span class="co-ml-full__return-icon" aria-hidden="true">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#00a650" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
    </span>
    <span>
      <span class="co-ml-full__return-title">Devolución gratis</span>
      <span class="co-ml-full__return-sub">durante 30 días</span>
    </span>
  </div>

</div>

<style>
  .co-ml-full {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px 14px;
    background: #f5faf6;
    border: 1px solid #b2dfba;
    border-radius: 12px;
    margin: 12px 0 8px;
  }
  .co-ml-full__badge {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .co-ml-full__badge--delivery {
    background: #e8f5e9;
    border-radius: 8px;
    padding: 5px 10px;
    flex-wrap: wrap;
    gap: 4px;
  }
  .co-ml-full__badge-text {
    font-size: 0.875rem;
    font-weight: 600;
    color: #00a650;
  }
  .co-ml-full__pill-img {
    height: 22px;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }
  .co-ml-full__badge--return {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 2px 4px;
  }
  .co-ml-full__return-icon { display: flex; align-items: center; }
  .co-ml-full__return-title {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #00a650;
  }
  .co-ml-full__return-sub {
    display: block;
    font-size: 0.78rem;
    color: #555;
  }
</style>
