{%- liquid
  assign rating = 4.9
  assign reviews_count = '500+'
-%}

<style>
  .lp-rev-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 8px 0 14px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-rev-badge__avatars {
    display: flex;
    align-items: center;
  }
  .lp-rev-badge__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    margin-left: -10px;
    background: var(--lp-accent, #D6EEF5);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 1px 3px rgba(46, 63, 69, 0.12);
    overflow: hidden;
  }
  .lp-rev-badge__avatar:first-child { margin-left: 0; }
  .lp-rev-badge__avatar svg { width: 100%; height: 100%; display: block; }
  .lp-rev-badge__stars {
    color: #f5b301;
    font-size: 16px;
    letter-spacing: 1.5px;
    line-height: 1;
  }
  .lp-rev-badge__text {
    font-size: 13px;
    color: var(--lp-text-soft, #6B7E85);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }
</style>

<div class="lp-rev-badge">
  <div class="lp-rev-badge__avatars" aria-hidden="true">
    <span class="lp-rev-badge__avatar">
      <img src="https://auravitaoficial.com/cdn/shop/files/7_9a289982-8947-4672-8807-ec66364ac442_160x160.png?v=1777475736" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
    </span>
    <span class="lp-rev-badge__avatar">
      <img src="https://auravitaoficial.com/cdn/shop/files/4_5346aa31-1810-4dce-9897-cbe09eb5e859_160x160.png?v=1777475667" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
    </span>
    <span class="lp-rev-badge__avatar">
      <img src="https://auravitaoficial.com/cdn/shop/files/11.webp?v=1777475953&width=500" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
    </span>
  </div>
  <span class="lp-rev-badge__stars" aria-label="{{ rating }} de 5 estrellas">★★★★★</span>
  <a href="#lp-photo-tt" class="lp-rev-badge__text">({{ rating }}/5 — {{ reviews_count }} reseñas)</a>
</div>
