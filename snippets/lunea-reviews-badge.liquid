{%- liquid
  assign rating = 4.9
  assign reviews_count = '500+'
-%}

<style>
  .lp-rev-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 8px 0 14px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-rev-badge__avatars {
    display: flex;
    align-items: center;
  }
  .lp-rev-badge__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    margin-left: -10px;
    background: var(--lp-accent, #D6EEF5);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 1px 3px rgba(46, 63, 69, 0.12);
    overflow: hidden;
  }
  .lp-rev-badge__avatar:first-child { margin-left: 0; }
  .lp-rev-badge__avatar svg { width: 100%; height: 100%; display: block; }
  .lp-rev-badge__stars {
    color: #f5b301;
    font-size: 16px;
    letter-spacing: 1.5px;
    line-height: 1;
  }
  .lp-rev-badge__text {
    font-size: 13px;
    color: var(--lp-text-soft, #6B7E85);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }
</style>

<div class="lp-rev-badge">
  <div class="lp-rev-badge__avatars" aria-hidden="true">
    <span class="lp-rev-badge__avatar">
      <svg viewBox="0 0 32 32"><rect width="32" height="32" fill="#D6EEF5"/><circle cx="16" cy="13" r="5" fill="#7BBDD0"/><path d="M16 19c-5 0-9 3-9 8v5h18v-5c0-5-4-8-9-8z" fill="#7BBDD0"/></svg>
    </span>
    <span class="lp-rev-badge__avatar">
      <svg viewBox="0 0 32 32"><rect width="32" height="32" fill="#EBF6FA"/><circle cx="16" cy="13" r="5" fill="#A8D5E2"/><path d="M16 19c-5 0-9 3-9 8v5h18v-5c0-5-4-8-9-8z" fill="#A8D5E2"/></svg>
    </span>
    <span class="lp-rev-badge__avatar">
      <svg viewBox="0 0 32 32"><rect width="32" height="32" fill="#E4E8EA"/><circle cx="16" cy="13" r="5" fill="#6B7E85"/><path d="M16 19c-5 0-9 3-9 8v5h18v-5c0-5-4-8-9-8z" fill="#6B7E85"/></svg>
    </span>
  </div>
  <span class="lp-rev-badge__stars" aria-label="{{ rating }} de 5 estrellas">★★★★★</span>
  <a href="#lp-photo-tt" class="lp-rev-badge__text">({{ rating }}/5 — {{ reviews_count }} reseñas)</a>
</div>
