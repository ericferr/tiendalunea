<style>
  /* Wrapper para mantener el thumbnail visible mientras el video carga */
  .lunea-video-wrap {
    position: relative;
    display: block;
  }
  .lunea-video-thumb {
    position: absolute;
    inset: 0;
    object-fit: cover;
    width: 100%;
    height: 100%;
    pointer-events: none;
    transition: opacity 0.4s ease;
    z-index: 1;
  }
  .lunea-video-thumb.lunea-hidden {
    opacity: 0;
  }
</style>

<script>
(function () {

  /* ── Extrae el src del thumbnail del poster-button ── */
  function getPosterSrc(deferredEl) {
    var img = deferredEl.querySelector('.deferred-media__poster img, .media__poster img, button img');
    return img ? (img.src || img.dataset.src || '') : '';
  }

  /* ── Activa un deferred-media, setea poster y reproduce ── */
  function triggerDeferred(deferredEl) {
    if (deferredEl.dataset.luneaTriggered) return;
    deferredEl.dataset.luneaTriggered = '1';

    var posterSrc = getPosterSrc(deferredEl);

    /* Llama a loadContent() nativo de Shopify Dawn si existe */
    if (typeof deferredEl.loadContent === 'function') {
      deferredEl.loadContent(false);
    } else {
      var btn = deferredEl.querySelector('[id^="Deferred-Poster-Modal"], .deferred-media__poster, .deferred-media__poster-button');
      if (btn) btn.click();
    }

    /* MutationObserver: detecta cuando Shopify inserta el <video> en el DOM */
    var observer = new MutationObserver(function (mutations, obs) {
      var video = deferredEl.querySelector('video');
      if (!video) return;
      obs.disconnect();

      /* Aplica poster para evitar pantalla negra */
      if (posterSrc) video.setAttribute('poster', posterSrc);
      video.muted = true;
      video.setAttribute('muted', '');
      video.setAttribute('playsinline', '');
      video.setAttribute('preload', 'metadata');

      /* Thumbnail overlay encima del video mientras carga */
      if (posterSrc) {
        var parent = video.parentElement;
        if (parent && !parent.classList.contains('lunea-video-wrap')) {
          parent.classList.add('lunea-video-wrap');
          var thumb = document.createElement('img');
          thumb.src = posterSrc;
          thumb.className = 'lunea-video-thumb';
          thumb.setAttribute('aria-hidden', 'true');
          parent.appendChild(thumb);

          video.addEventListener('canplay', function () {
            thumb.classList.add('lunea-hidden');
            video.play().catch(function () {});
          }, { once: true });
        }
      } else {
        video.play().catch(function () {});
      }
    });
    observer.observe(deferredEl, { childList: true, subtree: true });
  }

  /* ── Hero: activa el primer video del producto ── */
  function autoplayHero() {
    var hero = document.querySelector('.product__media-list deferred-media, .product__media-item deferred-media');
    if (hero) triggerDeferred(hero);
  }

  /* ── Scroll autoplay con IntersectionObserver ── */
  function setupScrollAutoplay() {
    if (!('IntersectionObserver' in window)) return;

    var skippedHero = false;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        triggerDeferred(el);
        observer.unobserve(el);
      });
    }, { threshold: 0.35 });

    document.querySelectorAll('deferred-media').forEach(function (el) {
      /* Salta el hero — ya lo manejamos con autoplayHero() */
      if (!skippedHero && el.closest('.product__media-list, .product__media-item')) {
        skippedHero = true;
        return;
      }
      observer.observe(el);
    });
  }

  /* ── Init ── */
  function init() {
    setTimeout(autoplayHero, 700);
    setupScrollAutoplay();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
