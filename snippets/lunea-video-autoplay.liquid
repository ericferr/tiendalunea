<script>
(function () {
  /* ─── Helpers ─── */
  function muteAndPlay(video) {
    if (!video) return;
    video.muted = true;
    video.setAttribute('muted', '');
    video.setAttribute('playsinline', '');
    video.play().catch(function () {});
  }

  function triggerDeferred(deferredEl) {
    if (deferredEl.dataset.luneaTriggered) return;
    deferredEl.dataset.luneaTriggered = '1';
    var btn = deferredEl.querySelector('.deferred-media__poster, .deferred-media__poster-button, [id^="Deferred-Poster-Modal"]');
    if (btn) btn.click();
    // After Shopify loads the template content, mute & play the video
    setTimeout(function () {
      muteAndPlay(deferredEl.querySelector('video'));
    }, 600);
  }

  /* ─── 1. Hero: auto-trigger el primer video del producto ─── */
  function autoplayHero() {
    var hero = document.querySelector('.product__media-list deferred-media, .product__media-item deferred-media');
    if (hero) triggerDeferred(hero);
  }

  /* ─── 2. Scroll autoplay: IntersectionObserver ─── */
  function setupScrollAutoplay() {
    if (!('IntersectionObserver' in window)) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;

        if (el.tagName === 'VIDEO') {
          muteAndPlay(el);
        } else {
          // deferred-media no cargado aún
          triggerDeferred(el);
        }
        observer.unobserve(el);
      });
    }, { threshold: 0.4 });

    // Observa todos los deferred-media excepto el hero (ya lo manejamos arriba)
    var all = document.querySelectorAll('deferred-media, video');
    var isFirst = true;
    all.forEach(function (el) {
      if (isFirst && el.closest('.product__media-list, .product__media-item')) {
        isFirst = false; // skip hero
        return;
      }
      observer.observe(el);
    });
  }

  /* ─── Init ─── */
  function init() {
    setTimeout(autoplayHero, 700);
    setupScrollAutoplay();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
