<style>
  .lp-bcta {
    background: linear-gradient(160deg, #0f3d4f 0%, #1a6b82 100%);
    padding: 56px 24px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .lp-bcta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 20%, rgba(255,255,255,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .lp-bcta__eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-bottom: 14px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-bcta__title {
    font-size: clamp(24px, 5vw, 36px);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.2;
    margin: 0 0 10px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-bcta__title em {
    font-style: normal;
    color: #7ee8c3;
  }
  .lp-bcta__sub {
    font-size: 15px;
    color: rgba(255,255,255,0.70);
    margin: 0 0 32px;
    font-family: 'DM Sans', system-ui, sans-serif;
    max-width: 420px;
    margin-left: auto;
    margin-right: auto;
  }
  .lp-bcta__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #ffffff;
    color: #0f3d4f;
    font-size: 17px;
    font-weight: 800;
    padding: 18px 40px;
    border-radius: 50px;
    text-decoration: none;
    font-family: 'DM Sans', system-ui, sans-serif;
    letter-spacing: 0.01em;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 8px 28px rgba(0,0,0,0.25);
    cursor: pointer;
    border: none;
  }
  .lp-bcta__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 36px rgba(0,0,0,0.32);
    color: #0f3d4f;
    text-decoration: none;
  }
  .lp-bcta__trust {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  .lp-bcta__trust-item {
    font-size: 12px;
    color: rgba(255,255,255,0.60);
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
</style>

<section class="lp-bcta">
  <span class="lp-bcta__eyebrow">{{ section.settings.eyebrow }}</span>
  <h2 class="lp-bcta__title">{{ section.settings.title | newline_to_br }}</h2>
  <p class="lp-bcta__sub">{{ section.settings.subtitle }}</p>

  <a href="#main-product-form" class="lp-bcta__btn" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">
    🛍️ {{ section.settings.button_text }}
  </a>

  <div class="lp-bcta__trust">
    <span class="lp-bcta__trust-item">🚚 Envío gratis · 1-5 días</span>
    <span class="lp-bcta__trust-item">📦 Pago contra entrega</span>
    <span class="lp-bcta__trust-item">🛡️ Garantía 30 días</span>
  </div>
</section>

{% schema %}
{
  "name": "Lunea · CTA Final",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño superior",
      "default": "¿Lista para empezar?"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título principal",
      "default": "Tu lactancia merece ser libre"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Pídelo hoy y paga cuando llegue a tu puerta. Sin riesgo, sin tarjetas."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Comprar mi Lunea"
    }
  ],
  "presets": [
    {
      "name": "Lunea · CTA Final"
    }
  ]
}
{% endschema %}
