<div class="lunea-section lunea-bg-sky lunea-pad">
  <div class="lunea-container">
    <div class="lunea-text-center lunea-fade lunea-mb-lg">
      {% if section.settings.eyebrow != blank %}<span class="lunea-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      {% if section.settings.heading != blank %}<h2 style="margin-top:12px;">{{ section.settings.heading }}</h2>{% endif %}
      <div class="lunea-stars" style="font-size:1.4rem;margin-top:16px;">★★★★★</div>
      {% if section.settings.rating_text != blank %}<p class="lunea-text-muted" style="margin-top:6px;">{{ section.settings.rating_text }}</p>{% endif %}
    </div>
    <div class="lunea-testimonials-grid">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          <div class="lunea-testimonial lunea-fade" {{ block.shopify_attributes }}>
            <div class="lunea-stars">★★★★★</div>
            <p class="lunea-testimonial-text">{{ block.settings.quote }}</p>
            <div class="lunea-author">
              <div class="lunea-avatar">{{ block.settings.name | slice: 0 }}</div>
              <div>
                <div class="lunea-author-name">{{ block.settings.name }}</div>
                <div class="lunea-author-loc">{{ block.settings.location }}</div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<!-- URGENCY -->
<div class="lunea-section lunea-bg-dark lunea-urgency lunea-pad">
  <div class="lunea-container">
    {% if section.settings.urgency_eyebrow != blank %}<span class="lunea-eyebrow" style="color:var(--lunea-sky);">{{ section.settings.urgency_eyebrow }}</span>{% endif %}
    {% if section.settings.urgency_heading != blank %}<h2 style="margin-top:12px;">{{ section.settings.urgency_heading }}</h2>{% endif %}
    {% if section.settings.urgency_subtext != blank %}<p>{{ section.settings.urgency_subtext }}</p>{% endif %}
    {% if section.settings.urgency_price != blank %}<div class="lunea-urgency-price">{{ section.settings.urgency_price }}</div>{% endif %}
    {% if section.settings.urgency_note != blank %}<div class="lunea-urgency-note">{{ section.settings.urgency_note }}</div>{% endif %}
    {% if section.settings.urgency_cta_text != blank %}
      <a href="{{ section.settings.urgency_cta_url }}" class="lunea-btn-urgency">{{ section.settings.urgency_cta_text }}</a>
    {% endif %}
    <div class="lunea-urgency-perks">
      {% for block in section.blocks %}
        {% if block.type == 'urgency_perk' %}
          <div class="lunea-urgency-perk" {{ block.shopify_attributes }}>
            <span>{{ block.settings.icon }}</span>
            <span>{{ block.settings.text }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<!-- FAQ -->
<div class="lunea-section lunea-bg-white lunea-pad">
  <div class="lunea-container">
    <div class="lunea-faq-wrap">
      <div class="lunea-text-center lunea-fade lunea-mb-lg">
        {% if section.settings.faq_eyebrow != blank %}<span class="lunea-eyebrow">{{ section.settings.faq_eyebrow }}</span>{% endif %}
        {% if section.settings.faq_heading != blank %}<h2 style="margin-top:12px;">{{ section.settings.faq_heading }}</h2>{% endif %}
      </div>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          <div class="lunea-faq-item lunea-fade" {{ block.shopify_attributes }}>
            <div class="lunea-faq-q">{{ block.settings.question }}<div class="lunea-faq-icon">+</div></div>
            <div class="lunea-faq-a">{{ block.settings.answer }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<!-- GUARANTEE -->
<div class="lunea-section lunea-bg-sky lunea-pad">
  <div class="lunea-container lunea-fade">
    <div class="lunea-guarantee">
      <div class="lunea-seal">
        <div class="lunea-seal-days">{{ section.settings.guarantee_days }}</div>
        <div class="lunea-seal-text">Días de<br>garantía</div>
      </div>
      <div>
        {% if section.settings.guarantee_title != blank %}<h3>{{ section.settings.guarantee_title }}</h3>{% endif %}
        {% if section.settings.guarantee_text != blank %}<p class="lunea-guarantee-text">{{ section.settings.guarantee_text }}</p>{% endif %}
        <div style="margin-top:20px;display:flex;gap:16px;flex-wrap:wrap;">
          {% for block in section.blocks %}
            {% if block.type == 'guarantee_badge' %}
              <span style="display:flex;align-items:center;gap:6px;font-size:0.82rem;color:var(--lunea-gray-800);" {{ block.shopify_attributes }}>{{ block.settings.icon }} {{ block.settings.text }}</span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

