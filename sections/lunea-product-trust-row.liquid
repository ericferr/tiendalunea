{{ 'lunea-product.css' | asset_url | stylesheet_tag }}

<div class="lp-section" {{ section.shopify_attributes }}>
  <div class="lp-container">
    {%- if section.blocks.size > 0 -%}
      <div class="lp-trust-row">
        {%- for block in section.blocks -%}
          <div class="lp-trust-row__item" {{ block.shopify_attributes }}>
            <span class="lp-trust-row__icon">{{ block.settings.icon }}</span>
            <span>{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Lunea · Trust row",
  "tag": "section",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "trust",
      "name": "Garantía",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji", "default": "🚚" },
        { "type": "text", "id": "text", "label": "Texto", "default": "Envío gratis" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lunea · Trust row",
      "blocks": [
        { "type": "trust", "settings": { "icon": "🚚", "text": "Envío gratis" } },
        { "type": "trust", "settings": { "icon": "📦", "text": "Pago contra entrega" } },
        { "type": "trust", "settings": { "icon": "🛡️", "text": "Garantía 30 días" } },
        { "type": "trust", "settings": { "icon": "🔒", "text": "Compra segura" } }
      ]
    }
  ]
}
{% endschema %}
