<div class="hg">

  {% comment %} ── HERO ── {% endcomment %}
  <section class="hg-hero">
    <div class="hg-hero__inner">
      {%- if section.settings.eyebrow != blank -%}<span class="hg-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h1 class="hg-hero__title">{{ section.settings.heading }}</h1>{%- endif -%}
      {%- if section.settings.subheading != blank -%}<p class="hg-hero__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
  </section>

  {% comment %} ── CARRUSEL DE PRODUCTOS ── {% endcomment %}
  {%- if section.blocks.size > 0 -%}
  <section class="hg-products">
    <div class="hg-wrap">
      {%- if section.settings.products_title != blank -%}<h2 class="hg-h2">{{ section.settings.products_title }}</h2>{%- endif -%}
      <div class="hg-carousel">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.url }}" class="hg-card" {{ block.shopify_attributes }}>
            <div class="hg-card__media">
              {%- if block.settings.image_url != blank -%}
                <img src="{{ block.settings.image_url }}" alt="{{ block.settings.name }}" loading="lazy">
              {%- endif -%}
              {%- if block.settings.badge != blank -%}<span class="hg-card__badge">{{ block.settings.badge }}</span>{%- endif -%}
            </div>
            <div class="hg-card__body">
              <p class="hg-card__name">{{ block.settings.name }}</p>
              {%- if block.settings.tagline != blank -%}<p class="hg-card__tag">{{ block.settings.tagline }}</p>{%- endif -%}
              <div class="hg-card__prices">
                {%- if block.settings.anchor != blank -%}<span class="hg-card__anchor">{{ block.settings.anchor }}</span>{%- endif -%}
                <span class="hg-card__price">{{ block.settings.price }}</span>
              </div>
              <span class="hg-card__btn">Ver producto →</span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </section>
  {%- endif -%}

  {% comment %} ── FILA DE CONFIANZA ── {% endcomment %}
  <section class="hg-trust">
    <div class="hg-wrap hg-trust__grid">
      <div class="hg-trust__item"><span>🚚</span>Envío gratis a Colombia</div>
      <div class="hg-trust__item"><span>📦</span>Pago contra entrega</div>
      <div class="hg-trust__item"><span>⚡</span>Llega en 1 a 5 días</div>
      <div class="hg-trust__item"><span>🔒</span>Compra 100% segura</div>
    </div>
  </section>

</div>

<style>
  .hg { font-family: 'DM Sans', system-ui, sans-serif; color: #2E3F45; }
  .hg * { box-sizing: border-box; }
  .hg-wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }

  /* HERO */
  .hg-hero { background: linear-gradient(180deg, #eef6f9 0%, #fff 100%); padding: 54px 20px 40px; text-align: center; }
  .hg-hero__inner { max-width: 720px; margin: 0 auto; }
  .hg-eyebrow { display: inline-block; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #2a9dc5; margin-bottom: 14px; }
  .hg-hero__title { font-size: clamp(28px, 5vw, 44px); font-weight: 800; line-height: 1.15; margin: 0 0 14px; color: #1a2e35; }
  .hg-hero__sub { font-size: clamp(15px, 2vw, 18px); color: #5a6e75; line-height: 1.55; margin: 0 auto; max-width: 560px; }

  /* PRODUCTOS */
  .hg-products { padding: 40px 0 16px; }
  .hg-h2 { text-align: center; font-size: clamp(22px, 3vw, 30px); font-weight: 800; color: #1a2e35; margin: 0 0 26px; }
  .hg-carousel {
    display: flex; gap: 18px; overflow-x: auto; padding: 6px 4px 18px;
    scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
  }
  .hg-carousel::-webkit-scrollbar { height: 6px; }
  .hg-carousel::-webkit-scrollbar-thumb { background: #cde4ec; border-radius: 3px; }
  .hg-card {
    flex: 0 0 auto; width: 280px; scroll-snap-align: center;
    background: #fff; border: 1px solid #e6eef1; border-radius: 16px; overflow: hidden;
    text-decoration: none; color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex; flex-direction: column;
  }
  .hg-card:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(42,157,197,0.18); }
  .hg-card__media { position: relative; aspect-ratio: 1/1; background: #f4f9fb; }
  .hg-card__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hg-card__badge {
    position: absolute; top: 12px; left: 12px; background: #FF4D6D; color: #fff;
    font-size: 11px; font-weight: 800; padding: 4px 10px; border-radius: 20px; letter-spacing: 0.04em;
  }
  .hg-card__body { padding: 16px; display: flex; flex-direction: column; gap: 5px; flex: 1; }
  .hg-card__name { font-size: 16px; font-weight: 700; color: #1a2e35; margin: 0; line-height: 1.25; }
  .hg-card__tag { font-size: 13px; color: #6b7e85; margin: 0; line-height: 1.4; }
  .hg-card__prices { display: flex; align-items: baseline; gap: 8px; margin-top: 4px; }
  .hg-card__anchor { font-size: 13px; color: #aaa; text-decoration: line-through; }
  .hg-card__price { font-size: 20px; font-weight: 900; color: #2a9dc5; }
  .hg-card__btn {
    margin-top: 10px; display: inline-block; text-align: center;
    background: #2a9dc5; color: #fff; font-size: 14px; font-weight: 700;
    padding: 11px 14px; border-radius: 9px; transition: background 0.2s;
  }
  .hg-card:hover .hg-card__btn { background: #1a7a9a; }

  /* CONFIANZA */
  .hg-trust { padding: 30px 0 50px; }
  .hg-trust__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .hg-trust__item {
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 7px;
    background: #f4f9fb; border-radius: 12px; padding: 18px 10px;
    font-size: 13px; font-weight: 600; color: #2E3F45; line-height: 1.3;
  }
  .hg-trust__item span { font-size: 26px; }
  @media (max-width: 600px) { .hg-trust__grid { grid-template-columns: repeat(2, 1fr); } }
</style>

{% schema %}
{
  "name": "Home · Genérica",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Antetítulo", "default": "Bienestar & Belleza · Colombia" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Productos que cuidan de ti" },
    { "type": "textarea", "id": "subheading", "label": "Subtítulo", "default": "Selección de productos de salud y belleza, con envío gratis y pago contra entrega a todo el país." },
    { "type": "text", "id": "products_title", "label": "Título de la sección de productos", "default": "Nuestros productos" }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Producto",
      "settings": [
        { "type": "text", "id": "image_url", "label": "URL de imagen" },
        { "type": "text", "id": "name", "label": "Nombre" },
        { "type": "text", "id": "tagline", "label": "Frase corta" },
        { "type": "text", "id": "anchor", "label": "Precio tachado (opcional)" },
        { "type": "text", "id": "price", "label": "Precio" },
        { "type": "url", "id": "url", "label": "Enlace al producto" },
        { "type": "text", "id": "badge", "label": "Badge (opcional)" }
      ]
    }
  ],
  "presets": [{ "name": "Home · Genérica" }]
}
{% endschema %}
