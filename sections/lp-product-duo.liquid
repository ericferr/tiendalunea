{% comment %} ── Sección: Duo de productos Lunea ── {% endcomment %}
<section class="lp-duo" style="padding: {{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;">
  <div class="lp-duo__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="lp-duo__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="lp-duo__grid">

      <a href="{{ section.settings.product1_url }}" class="lp-duo__card">
        <div class="lp-duo__img-wrap">
          <img
            src="{{ section.settings.product1_img }}"
            alt="{{ section.settings.product1_name }}"
            class="lp-duo__img"
            loading="lazy"
          >
          <div class="lp-duo__gradient"></div>
        </div>
        <div class="lp-duo__info">
          <p class="lp-duo__name">{{ section.settings.product1_name }}</p>
          <p class="lp-duo__sub">{{ section.settings.product1_sub }}</p>
          <span class="lp-duo__btn">
            {{ section.settings.product1_price }}
            <span class="lp-duo__arrow">→</span>
          </span>
        </div>
      </a>

      <a href="{{ section.settings.product2_url }}" class="lp-duo__card">
        <div class="lp-duo__img-wrap">
          <img
            src="{{ section.settings.product2_img }}"
            alt="{{ section.settings.product2_name }}"
            class="lp-duo__img"
            loading="lazy"
          >
          <div class="lp-duo__gradient"></div>
          <span class="lp-duo__badge">{{ section.settings.product2_badge }}</span>
        </div>
        <div class="lp-duo__info">
          <p class="lp-duo__name">{{ section.settings.product2_name }}</p>
          <p class="lp-duo__sub">{{ section.settings.product2_sub }}</p>
          <span class="lp-duo__btn">
            {{ section.settings.product2_price }}
            <span class="lp-duo__arrow">→</span>
          </span>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  .lp-duo__inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .lp-duo__heading {
    text-align: center;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #1a1a1a;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-duo__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 600px) {
    .lp-duo__grid { grid-template-columns: 1fr; }
  }
  .lp-duo__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.10);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    background: #fff;
  }
  .lp-duo__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.15);
  }
  .lp-duo__img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .lp-duo__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .lp-duo__card:hover .lp-duo__img {
    transform: scale(1.03);
  }
  .lp-duo__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.25) 100%);
    pointer-events: none;
  }
  .lp-duo__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #0d6e82;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-duo__info {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .lp-duo__name {
    font-size: 17px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-duo__sub {
    font-size: 13px;
    color: #666;
    margin: 0 0 8px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-duo__btn {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: #0d6e82;
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    padding: 12px 16px;
    border-radius: 8px;
    font-family: 'DM Sans', system-ui, sans-serif;
    transition: background 0.2s ease;
    box-shadow: 0 2px 8px rgba(13,110,130,0.3);
  }
  .lp-duo__card:hover .lp-duo__btn {
    background: #0a5566;
  }
  .lp-duo__arrow {
    font-size: 18px;
  }
</style>

{% schema %}
{
  "name": "Duo de productos",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Nuestros productos" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Espaciado superior", "default": 32 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Espaciado inferior", "default": 32 },
    { "type": "header", "content": "Producto 1 — Lunea" },
    { "type": "url", "id": "product1_url", "label": "URL", "default": "/products/extractor-electrico-inalambrico" },
    { "type": "image_picker", "id": "product1_img_picker", "label": "Imagen (usar campo de texto si no carga)" },
    { "type": "text", "id": "product1_img", "label": "URL imagen", "default": "https://cdn.shopify.com/s/files/1/0811/0984/4194/files/preview_images/30c08e4240524eb6a58fb8214f72ffdc.thumbnail.0000000000.jpg" },
    { "type": "text", "id": "product1_name", "label": "Nombre", "default": "Lunea®" },
    { "type": "text", "id": "product1_sub", "label": "Subtítulo", "default": "Extractor completo con pantalla LED" },
    { "type": "text", "id": "product1_price", "label": "Precio en botón", "default": "Desde $219.000" },
    { "type": "header", "content": "Producto 2 — Lunea Go" },
    { "type": "url", "id": "product2_url", "label": "URL", "default": "/products/lunea-go" },
    { "type": "text", "id": "product2_img", "label": "URL imagen", "default": "https://cdn.shopify.com/s/files/1/0811/0984/4194/files/ImageToStl.com_Gemini_Generated_Image_dduzd1dduzd1dduz_1.avif" },
    { "type": "text", "id": "product2_name", "label": "Nombre", "default": "Lunea Go®" },
    { "type": "text", "id": "product2_sub", "label": "Subtítulo", "default": "Compacto · 276g · Entra en tu corpiño" },
    { "type": "text", "id": "product2_price", "label": "Precio en botón", "default": "Desde $135.000" },
    { "type": "text", "id": "product2_badge", "label": "Badge (ej: Nuevo)", "default": "✨ Más compacto" }
  ],
  "presets": [{ "name": "Duo de productos" }]
}
{% endschema %}
