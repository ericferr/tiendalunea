{%- assign url = section.settings.cta_url | default: '/products/physicians-choice-enzimas-digestivas' -%}

<div class="ez-home">

  {% comment %} ── HERO ── {% endcomment %}
  <section class="ezh-hero">
    <div class="ezh-hero__inner">
      <span class="ezh-eyebrow">Physician's Choice · Marca #1 en EE.UU. 🇺🇸</span>
      <h1 class="ezh-hero__title">¿Te hinchás después de comer?<br><em>No es normal — y tiene solución.</em></h1>
      <p class="ezh-hero__sub">Enzimas digestivas + probióticos + prebióticos en una sola cápsula. Digestión liviana, sin gases ni pesadez, desde los primeros días.</p>
      <a href="{{ url }}" class="ezh-btn">📦 Quiero el mío — Pago al recibirlo</a>
      <p class="ezh-hero__trust">🚚 Envío gratis · 💵 Pago contra entrega o Nequi · ⭐ 4.9/5</p>

      <div class="ezh-badges">
        <div class="ezh-badge"><span>🩺</span>Desarrollado con médicos</div>
        <div class="ezh-badge"><span>🇺🇸</span>Marca #1 en EE.UU.</div>
        <div class="ezh-badge"><span>🌿</span>Fórmula natural</div>
        <div class="ezh-badge"><span>🔬</span>Sin efectos secundarios</div>
      </div>
    </div>
  </section>

  {% comment %} ── BENEFICIOS ── {% endcomment %}
  <section class="ezh-section">
    <div class="ezh-wrap">
      <p class="ezh-kicker">Por qué funciona</p>
      <h2 class="ezh-h2">Una cápsula. Tres soluciones.</h2>
      <div class="ezh-grid3">
        <div class="ezh-card">
          <div class="ezh-card__ic">⚗️</div>
          <h3>16 enzimas digestivas</h3>
          <p>Descomponen proteínas, grasas y carbohidratos. Tu cuerpo absorbe más y trabaja menos después de comer.</p>
        </div>
        <div class="ezh-card">
          <div class="ezh-card__ic">🦠</div>
          <h3>2 Billones de probióticos</h3>
          <p>Restauran el equilibrio de tu flora intestinal. Menos gases, menos inflamación, más bienestar.</p>
        </div>
        <div class="ezh-card">
          <div class="ezh-card__ic">🌱</div>
          <h3>Prebióticos incluidos</h3>
          <p>Alimentan las bacterias buenas para que los probióticos funcionen mejor. La mayoría no los incluye.</p>
        </div>
      </div>
    </div>
  </section>

  {% comment %} ── PRUEBA SOCIAL ── {% endcomment %}
  <section class="ezh-proof">
    <div class="ezh-wrap">
      <div class="ezh-stars">★★★★★</div>
      <p class="ezh-proof__quote">"Después de 10 días ya no me hincho después del almuerzo. Es lo mejor que probé y el pago contra entrega me dio total tranquilidad."</p>
      <p class="ezh-proof__name">Valentina C. · Medellín · Compra verificada</p>
    </div>
  </section>

  {% comment %} ── CÓMO SE USA ── {% endcomment %}
  <section class="ezh-section">
    <div class="ezh-wrap">
      <p class="ezh-kicker">Así de simple</p>
      <h2 class="ezh-h2">Sin cambiar tu dieta</h2>
      <div class="ezh-grid3">
        <div class="ezh-step"><span class="ezh-step__n">1</span><p>Tomá 1 cápsula con agua antes de tu comida principal.</p></div>
        <div class="ezh-step"><span class="ezh-step__n">2</span><p>Seguí con tu día normal — en casa, en el trabajo, donde sea.</p></div>
        <div class="ezh-step"><span class="ezh-step__n">3</span><p>Sentí la diferencia: menos hinchazón y más energía en 7-14 días.</p></div>
      </div>
    </div>
  </section>

  {% comment %} ── CTA FINAL ── {% endcomment %}
  <section class="ezh-final">
    <div class="ezh-wrap">
      <h2 class="ezh-final__title">Tu digestión merece una solución real</h2>
      <p class="ezh-final__sub">La marca #1 en enzimas digestivas de EE.UU., ahora en Colombia. Pedila hoy y pagá cuando te llega.</p>
      <a href="{{ url }}" class="ezh-btn ezh-btn--light">📦 Pedir ahora — Pago al recibirlo</a>
      <p class="ezh-final__trust">🚚 Envío gratis a todo el país · Llega en 1 a 5 días</p>
    </div>
  </section>

</div>

<style>
  .ez-home { font-family: 'DM Sans', system-ui, sans-serif; color: #2E3F45; }
  .ez-home * { box-sizing: border-box; }
  .ezh-wrap { max-width: 1040px; margin: 0 auto; padding: 0 20px; }

  /* HERO */
  .ezh-hero { background: linear-gradient(180deg, #FEF3F3 0%, #fff 100%); padding: 56px 20px 48px; text-align: center; }
  .ezh-hero__inner { max-width: 760px; margin: 0 auto; }
  .ezh-eyebrow { display: inline-block; font-size: 13px; font-weight: 700; color: #B22222; letter-spacing: 0.04em; margin-bottom: 16px; }
  .ezh-hero__title { font-size: clamp(28px, 5vw, 46px); font-weight: 800; line-height: 1.12; margin: 0 0 16px; color: #1a2e35; }
  .ezh-hero__title em { color: #B22222; font-style: normal; }
  .ezh-hero__sub { font-size: clamp(15px, 2vw, 18px); color: #5a6e75; line-height: 1.55; margin: 0 auto 26px; max-width: 580px; }
  .ezh-hero__trust { font-size: 13px; color: #6B7E85; font-weight: 600; margin: 14px 0 0; }

  .ezh-btn { display: inline-block; background: #B22222; color: #fff; font-size: 17px; font-weight: 700; padding: 16px 36px; border-radius: 50px; text-decoration: none; box-shadow: 0 8px 24px rgba(178,34,34,0.35); transition: transform 0.15s, box-shadow 0.15s; }
  .ezh-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(178,34,34,0.45); color: #fff; }
  .ezh-btn--light { background: #fff; color: #B22222; }
  .ezh-btn--light:hover { color: #B22222; }

  .ezh-badges { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 34px; }
  .ezh-badge { display: flex; flex-direction: column; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: #6B1515; background: #fff; border: 1px solid #F0C0C0; border-radius: 12px; padding: 14px 8px; text-align: center; line-height: 1.3; }
  .ezh-badge span { font-size: 26px; }
  @media (max-width: 560px) { .ezh-badges { grid-template-columns: repeat(2, 1fr); } }

  /* SECCIONES */
  .ezh-section { padding: 52px 0; }
  .ezh-kicker { text-align: center; font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #B22222; margin: 0 0 8px; }
  .ezh-h2 { text-align: center; font-size: clamp(24px, 3.5vw, 34px); font-weight: 800; color: #1a2e35; margin: 0 0 32px; }

  .ezh-grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 749px) { .ezh-grid3 { grid-template-columns: 1fr; } }
  .ezh-card { background: #fff; border: 1px solid #F0C0C0; border-radius: 16px; padding: 28px 22px; text-align: center; }
  .ezh-card__ic { width: 60px; height: 60px; margin: 0 auto 14px; border-radius: 14px; background: #FEF3F3; display: flex; align-items: center; justify-content: center; font-size: 30px; }
  .ezh-card h3 { font-size: 18px; font-weight: 700; color: #1a2e35; margin: 0 0 8px; }
  .ezh-card p { font-size: 14.5px; color: #5a6e75; line-height: 1.55; margin: 0; }

  .ezh-step { text-align: center; padding: 10px; }
  .ezh-step__n { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; background: #B22222; color: #fff; font-size: 22px; font-weight: 800; margin-bottom: 12px; }
  .ezh-step p { font-size: 15px; color: #5a6e75; line-height: 1.5; margin: 0; }

  /* PRUEBA SOCIAL */
  .ezh-proof { background: #FEF3F3; padding: 48px 0; text-align: center; }
  .ezh-stars { color: #f5b301; font-size: 24px; letter-spacing: 3px; margin-bottom: 16px; }
  .ezh-proof__quote { font-size: clamp(18px, 2.4vw, 24px); font-weight: 600; color: #2E3F45; line-height: 1.4; max-width: 680px; margin: 0 auto 14px; font-style: italic; }
  .ezh-proof__name { font-size: 14px; color: #6B7E85; font-weight: 600; margin: 0; }

  /* CTA FINAL */
  .ezh-final { background: linear-gradient(160deg, #6B1515 0%, #B22222 100%); padding: 56px 20px; text-align: center; color: #fff; }
  .ezh-final__title { font-size: clamp(24px, 4vw, 36px); font-weight: 800; margin: 0 0 12px; color: #fff; }
  .ezh-final__sub { font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.55; max-width: 540px; margin: 0 auto 28px; }
  .ezh-final__trust { font-size: 13px; color: rgba(255,255,255,0.75); margin: 18px 0 0; font-weight: 600; }
</style>

{% schema %}
{
  "name": "Enzimas · Home",
  "settings": [
    { "type": "url", "id": "cta_url", "label": "URL del botón (producto)" }
  ],
  "presets": [{ "name": "Enzimas · Home" }]
}
{% endschema %}
