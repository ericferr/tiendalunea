{{ 'lunea-product.css' | asset_url | stylesheet_tag }}

<style>
  .lp-vr {
    padding: 2rem 1rem;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .lp-vr__container { max-width: 1100px; margin: 0 auto; }
  .lp-vr__head { text-align: center; margin-bottom: 1.25rem; }
  .lp-vr__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 600;
    color: var(--lp-text, #2E3F45);
    line-height: 1.15;
    margin: 0 0 0.6rem;
  }
  .lp-vr__ig {
    display: inline-flex; align-items: center; gap: 8px;
    border: 1px solid var(--lp-border, #E4E8EA);
    background: #fff; border-radius: 999px;
    padding: 6px 14px 6px 8px;
    font-size: 13px; color: var(--lp-text, #2E3F45); font-weight: 500;
  }
  .lp-vr__ig-logo {
    width: 24px; height: 24px; border-radius: 6px;
    background: linear-gradient(45deg, #f9ce34, #ee2a7b 50%, #6228d7);
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .lp-vr__ig-logo svg { width: 14px; height: 14px; fill: #fff; }

  /* ── Fila horizontal única ── */
  .lp-vr__row {
    display: flex;
    flex-direction: row;
    gap: 10px;
    justify-content: center;
    align-items: flex-start;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .lp-vr__row::-webkit-scrollbar { display: none; }

  .lp-vr__card {
    position: relative;
    flex: 0 0 auto;
    width: 130px;
    aspect-ratio: 9/16;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(46,63,69,0.15);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .lp-vr__card:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 28px rgba(42,157,197,0.25);
  }
  @media (min-width: 600px) {
    .lp-vr__card { width: 160px; }
  }

  .lp-vr__video {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }
  .lp-vr__label {
    position: absolute;
    bottom: 10px; left: 0; right: 0;
    text-align: center;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 100%);
    color: #fff;
    font-weight: 700;
    font-size: 11px;
    line-height: 1.2;
    padding: 18px 8px 8px;
    letter-spacing: 0.02em;
    font-family: 'DM Sans', system-ui, sans-serif;
    transition: opacity 0.2s;
  }
  /* Al hacer tap — mostrar controles */
  .lp-vr__card.is-active .lp-vr__label { opacity: 0; }
  .lp-vr__card.is-active .lp-vr__video { pointer-events: auto; }
</style>

<div class="lp-vr" {{ section.shopify_attributes }}>
  <div class="lp-vr__container">
    <div class="lp-vr__head">
      {%- if section.settings.title != blank -%}
        <h2 class="lp-vr__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.ig_text != blank -%}
        <span class="lp-vr__ig">
          <span class="lp-vr__ig-logo" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.86 5.86 0 0 0-2.13 1.38A5.86 5.86 0 0 0 .63 4.14C.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.73 1.47 1.38 2.13a5.86 5.86 0 0 0 2.13 1.38c.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.86 5.86 0 0 0 2.13-1.38 5.86 5.86 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.86 5.86 0 0 0-1.38-2.13A5.86 5.86 0 0 0 19.86.63C19.1.33 18.22.13 16.95.07 15.67.01 15.26 0 12 0Zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32Zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.4-11.84a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88Z"/></svg>
          </span>
          {{ section.settings.ig_text }}
        </span>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="lp-vr__row" id="lp-vr-row-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="lp-vr__card" data-lp-vr-card {{ block.shopify_attributes }}>
            <video
              class="lp-vr__video"
              data-lp-vr-video
              src="{{ block.settings.video_url }}"
              {% if block.settings.poster_url != blank %}poster="{{ block.settings.poster_url }}"{% endif %}
              autoplay
              muted
              loop
              playsinline
              preload="auto"
            ></video>
            {%- if block.settings.label != blank -%}
              <div class="lp-vr__label">{{ block.settings.label }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
(function() {
  // Intersection Observer — autoplay solo cuando es visible
  var videos = document.querySelectorAll('[data-lp-vr-video]');
  if (!('IntersectionObserver' in window)) {
    videos.forEach(function(v) { v.play(); });
    return;
  }
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.play(); }
      else { e.target.pause(); }
    });
  }, { threshold: 0.3 });
  videos.forEach(function(v) { obs.observe(v); });

  // Tap para activar sonido / controles
  document.querySelectorAll('[data-lp-vr-card]').forEach(function(card) {
    card.addEventListener('click', function() {
      var v = card.querySelector('[data-lp-vr-video]');
      if (!v) return;
      var isActive = card.classList.contains('is-active');
      document.querySelectorAll('[data-lp-vr-card]').forEach(function(c) {
        c.classList.remove('is-active');
        var cv = c.querySelector('[data-lp-vr-video]');
        if (cv) { cv.muted = true; cv.controls = false; }
      });
      if (!isActive) {
        card.classList.add('is-active');
        v.muted = false;
        v.controls = true;
        v.play();
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Lunea · Videos reseñas",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "title", "label": "Título", "default": "Amada por más de 5.000 mamás" },
    { "type": "text", "id": "ig_text", "label": "Texto badge Instagram", "default": "Más de 1 millón de visitas en Instagram" }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video reseña",
      "settings": [
        { "type": "text", "id": "video_url", "label": "URL del video (.mp4)" },
        { "type": "text", "id": "poster_url", "label": "URL de la imagen poster (opcional)" },
        { "type": "text", "id": "label", "label": "Texto overlay", "default": "Reseña real" }
      ]
    }
  ],
  "presets": [
    { "name": "Lunea · Videos reseñas" }
  ]
}
{% endschema %}
